# ═══════════════════════════════════════════════════════════════════════════════
# AI RAG Chatbot Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 🗄️ DATABASE CONFIGURATION (Optional - Auto-detects storage mode)
# ─────────────────────────────────────────────────────────────────────────────
# Leave empty or unset for local file-based storage (development)
# Set for Vercel/production to use PostgreSQL persistence
#
# Connection String Format:
#   postgresql://username:password@host:port/database
#
# Get a free PostgreSQL database from:
#   - Neon: https://neon.tech (recommended for Vercel)
#   - Railway: https://railway.app
#   - Vercel Postgres: https://vercel.com/postgres
#   - AWS RDS, Google Cloud SQL, etc.
#
# Example (Neon):
#   postgresql://neondb_owner:AbCdEfGh@ep-xyz.us-east-1.neon.tech/neondb?sslmode=require
#
# Leave this UNSET in .env.local for local file-based development
# DATABASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 GROQ API CONFIGURATION (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
# No credit card required. Completely FREE!

GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# ─────────────────────────────────────────────────────────────────────────────
# 🤖 MODEL SELECTION
# ─────────────────────────────────────────────────────────────────────────────
# Choose which Groq model to use (all are FREE)
# Options:
#   - "mixtral-8x7b-32768" (RECOMMENDED: Balanced speed & quality)
#   - "gemma-7b-it" (Lightweight, quick responses)
#   - "llama2-70b-4096" (Most powerful)
#   - "qwen/qwen3.6-27b" (Fast, high quality)

GROQ_MODEL=mixtral-8x7b-32768

# ─────────────────────────────────────────────────────────────────────────────
# 🚀 SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Environment mode
# Options: development, production
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# 💾 FILE STORAGE CONFIGURATION (Local Development Only)
# ─────────────────────────────────────────────────────────────────────────────
# These are used ONLY when DATABASE_URL is not set
# On Vercel with DATABASE_URL, these are ignored

# Path to documents storage
DB_PATH=./data/documents.json

# Path to embeddings storage
EMBEDDINGS_PATH=./data/embeddings.json

# ─────────────────────────────────────────────────────────────────────────────
# 🧠 RAG (Retrieval-Augmented Generation) CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Maximum length of context to send to the model (in tokens)
MAX_CONTEXT_LENGTH=4000

# Maximum tokens in model response
MAX_TOKENS=2048

# Number of documents to retrieve for each query
# Higher = more context but may include less relevant docs
TOP_K_RESULTS=5

# Minimum similarity score to include a document (0.0 to 1.0)
# Lower = more documents included, Higher = only most relevant
MIN_SIMILARITY_SCORE=0.3

# ─────────────────────────────────────────────────────────────────────────────
# 📝 LOGGING CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Options: ERROR, WARN, INFO, DEBUG

LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT GUIDE
# ═══════════════════════════════════════════════════════════════════════════════
#
# LOCAL DEVELOPMENT:
#   1. Leave DATABASE_URL unset or empty
#   2. App uses file-based storage (data/documents.json, data/embeddings.json)
#   3. Run: npm run dev
#
# VERCEL PRODUCTION:
#   1. Set DATABASE_URL to your PostgreSQL connection string
#   2. Set GROQ_API_KEY to your Groq API key
#   3. Set NODE_ENV=production
#   4. App auto-detects DATABASE_URL and uses PostgreSQL
#   5. Documents persist across deployments
#   6. Deploy: git push (auto-deployed) or vercel deploy --prod
#
# For detailed instructions, see: VERCEL_DEPLOYMENT.md
# ═══════════════════════════════════════════════════════════════════════════════

